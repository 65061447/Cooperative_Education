{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "nodemon": "nodemon --exec npm run server",
    "server": "nodemon api/SQL.ts",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "electron:dev": "concurrently \"npm run dev\" \"npm run server\" \"wait-on http://localhost:8080 && electron .\"",
    "electron:build": "set ELECTRON=true&& vite build && tsc api/SQL.ts --outDir dist_api --module CommonJS --target ES6 --moduleResolution node --esModuleInterop --skipLibCheck --allowSyntheticDefaultImports && electron-builder"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
